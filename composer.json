{
    "name": "symfinity/ui-action",
    "description": "Symfinity UI Action — native HTTP action semantics validation (navigate, submit, delete, download)",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Symfinity\\UiAction\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfinity\\UiAction\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "version": "0.1.0-dev",
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    }
}
